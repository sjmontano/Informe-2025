{
  "name": "fondo-lunaria",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "design:lint": "npx @google/design.md lint DESIGN.md",
    "design:diff": "npx @google/design.md diff DESIGN.md",
    "impeccable": "impeccable detect src/",
    "impeccable:json": "impeccable detect src/ --json",
    "agents:check": "npm run design:lint && npm run impeccable",
    "agents:install": "npm i --save-dev agentation",
    "agents:run": "npx agentation run --dir agents"
  },
  "dependencies": {
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@google/design.md": "^0.1.1",
    "agentation": "^1.3.2",
    "impeccable": "^2.1.8"
  }
}
