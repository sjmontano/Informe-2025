<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Favicon -->
    <link rel="icon" href="/logo.ico" />

    <title>Informe de Gestión 2025</title>

    <!-- Lato — Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Preload del primer fondo (LCP) -->
    <link
      rel="preload"
      as="image"
      href="/resources/fondos/fondo-seccion-01-sm.webp"
      media="(max-width: 640px)"
    />
    <link
      rel="preload"
      as="image"
      href="/resources/fondos/fondo-seccion-01.webp"
      media="(min-width: 641px)"
    />

    <!-- Preload de Discordia Bold (títulos y cifras) -->
    <link
      rel="preload"
      as="font"
      href="/fonts/Discordia-Bold.woff2"
      crossorigin
    />
  </head>
  <body>
    <div class="scene-wrapper">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  /* Discordia — fuente de títulos (Aquelarre Laboratorio de Diseño Feminista) */
  @font-face {
    font-family: "Discordia";
    src:
      url("/fonts/Discordia-Regular.woff2") format("woff2"),
      url("/fonts/Discordia-Regular.woff") format("woff");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Discordia";
    src: url("/fonts/Discordia-Bold.woff2") format("woff2");
    font-weight: 700;
    font-style: bold;
    font-display: swap;
  }

  @font-face {
    font-family: "Discordia";
    src: url("/fonts/Discordia-Italic.woff2") format("woff2");
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Discordia";
    src: url("/fonts/Discordia-BoldItalic.woff2") format("woff2");
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  /* =========================================
     DESIGN TOKENS — Marea Feminista
     Fuente: DESIGN.md
     ========================================= */
  :root {
    /* Fondos — arena y océano */
    --bg-sand: #f4c454;
    --bg-ocean: #0b6b6d;

    /* Textos y estructura */
    --text-main: #28275b;
    --wood-accent: #ed7a22;

    /* Botones y CTAs */
    --cta-pink: #eba5c8;
    --cta-coral: #ef7e7b;

    /* Componentes especializados */
    --circle-bg: #1f1a3e;
    --circle-text: #fde070;
    --map-base: #28275b;
    --map-selected: #39b490;

    /* Tipografía */
    --font-heading: "Discordia", serif;
    --font-body: "Lato", sans-serif;

    /* Espaciado (DESIGN.md § Layout) */
    --spacing-xs: 4px;
    --spacing-sm: 8px;
    --spacing-md: 16px;
    --spacing-lg: 24px;
    --spacing-xl: 32px;
    --spacing-2xl: 48px;
    --spacing-3xl: 64px;
    --spacing-4xl: 96px;

    /* Altura de la escena. Cada sección ocupa 56.25vw (16:9).
       Multiplicar 0.5625 × cantidad de secciones de esta página.
       Otras páginas sobreescriben este valor con <style is:global>. */
    --alto: calc(100vw * 0.5625 * 3);
  }

  /* Reset base */
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: var(--font-body);
    background-color: transparent;
    color: var(--text-main);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  .scene-wrapper {
    position: relative;
    min-height: var(--alto);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>
