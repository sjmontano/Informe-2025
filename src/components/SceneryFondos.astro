---
/**
 * SceneryFondos.astro — Fondo de escena del Informe de Gestión 2025
 *
 * Apila 17 imágenes ilustradas como telón detrás del contenido.
 * Cada capa ocupa 1/17 de la altura total definida por --alto (Layout.astro).
 *
 * Placeholder LQIP: capa independiente con miniatura inline difuminada que
 * aparece al instante. La imagen real hace fade-in encima y oculta el LQIP.
 *
 * CÓMO MODIFICAR
 *   Cambiar imagen:  reemplazar el .webp en public/resources/fondos/
 *                    y regenerar variantes con node scripts/generar-variantes-fondos.mjs
 *   Cambiar orden:   reordenar las entradas del array FONDOS
 *   Agregar/quitar:  modificar TOTAL y el array, luego ejecutar el script
 *   Altura de capas: modificar --alto en src/layouts/Layout.astro
 */

import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const TOTAL = 17;

const SECCIONES = [
  'Portada del Informe de Gestión 2025',
  'Carta de la dirección del Fondo Lunaria',
  'Apoyamos — cifras clave de la gestión',
  'Programas — Libertad y Democracia',
  'Programas — Autonomía, Derechos y Sostenibilidad',
  'Fondo en Movimiento — apoyos ágiles',
  'Investigación — podcast y publicaciones',
  'Diseño e ilustración por Aquelarre Laboratorio de Diseño Feminista',
  'Testimonios de las organizaciones y colectivas',
  'Cuentas Claras — transparencia financiera',
  'Territorios y presencia en 29 departamentos',
  'Detalle de los programas y estrategias',
  'Alianzas y copartes que hacen posible la travesía',
  'Investigación en profundidad — hallazgos',
  'Proyección y continuidad de la marea',
  'Agradecimientos a quienes navegan con nosotras',
  'Cierre — horizonte colectivo, brújula al Sur',
] as const;

const BASE = join(process.cwd(), 'public', 'resources', 'fondos');

const FONDOS = Array.from({ length: TOTAL }, (_, i) => {
  const nro = String(i + 1).padStart(2, '0');
  let lqip = '';
  try {
    const buf = readFileSync(join(BASE, `fondo-seccion-${nro}-lqip.webp`));
    lqip = `data:image/webp;base64,${buf.toString('base64')}`;
  } catch { /* sin LQIP: la capa arranca sin placeholder */ }

  return {
    nro,
    seccion: SECCIONES[i],
    src: `/resources/fondos/fondo-seccion-${nro}.webp`,
    srcSm: `/resources/fondos/fondo-seccion-${nro}-sm.webp`,
    lqip,
    top: i * (100 / TOTAL),
    alt: `${SECCIONES[i]}, ilustración de Aquelarre Laboratorio de Diseño Feminista`,
    eager: i < 3,
  };
});
---

<div class="fondos" aria-hidden="true">
  {
    FONDOS.map((f) => (
      <div
        class={`fondos__capa fondos__capa--${f.nro}`}
        style={`top: ${f.top.toFixed(4)}%`}
      >
        {f.lqip && (
          <div
            class="fondos__lqip"
            style={`background-image: url(${f.lqip})`}
          />
        )}
        <picture>
          <source srcset={f.srcSm} media="(max-width: 640px)" />
          <img
            class="fondos__img"
            src={f.src}
            alt={f.alt}
            loading={f.eager ? 'eager' : 'lazy'}
            decoding="async"
            fetchpriority={f.nro === '01' ? 'high' : 'auto'}
          />
        </picture>
      </div>
    ))
  }
</div>

<script>
  document.querySelectorAll('.fondos__img').forEach(img => {
    if (img.complete) {
      img.style.opacity = '1';
      const lqip = img.closest('.fondos__capa')?.querySelector('.fondos__lqip');
      if (lqip) lqip.style.opacity = '0';
    } else {
      img.addEventListener('load', function () {
        const capa = this.closest('.fondos__capa');
        const lqip = capa ? capa.querySelector('.fondos__lqip') : null;
        if (lqip) lqip.style.opacity = '0';
        this.style.opacity = '1';
      });
    }
  });
</script>

<style>
  .fondos {
    position: absolute;
    inset: 0;
    width: 100%;
    height: var(--alto);
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }

  .fondos__capa {
    position: absolute;
    left: 0;
    width: 100%;
    height: 5.8824%;
    overflow: hidden;
    user-select: none;
  }

  .fondos__lqip {
    position: absolute;
    inset: -2%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(14px);
    z-index: 0;
    transition: opacity 0.3s ease;
  }

  .fondos__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 0.5s ease;
    will-change: opacity;
  }

  /*
   * Clases por capa — usar si una imagen necesita ajustes individuales.
   * Ejemplo: .fondos__capa--03 .fondos__lqip { background-position: top center; }
   */
</style>
