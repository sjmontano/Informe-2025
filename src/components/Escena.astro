/**
 * Escena.astro — Elementos decorativos por sección
 *
 * Props:
 *   desde  (default 0)  — primera sección a mostrar
 *   hasta  (default 16) — última sección a mostrar
 *
 * Cada sección es un array plano. Agregar/borrar un elemento = una línea.
 * top(seccion, offset): calcula posición relativa a las secciones visibles.
 * Sección global s se convierte a índice local automáticamente.
 */

export interface Props {
  desde?: number;
  hasta?: number;
}

const { desde = 0, hasta = 16 } = Astro.props;
const TOTAL = hasta - desde + 1;
const SEC = 100 / TOTAL;

const top = (s: number, fraccion: number) => {
  const local = s - desde;
  return `calc(${((local + fraccion) * SEC).toFixed(4)} * var(--alto) / 100)`;
};

const enRango = (s: number) => s >= desde && s <= hasta;

type Item = { src: string; css: string; alt: string; z?: number };

