---
// Welcome.astro — Hero placeholder del Informe de Gestión 2025
// Reemplaza el template default de Astro con la identidad Fondo Lunaria
---

<section class="hero">
  <div class="hero-content">
    <span class="hero-tag">Informe de Gestión 2025</span>
    <h1 class="hero-title">Orillas que abrazan.<br />Mareas que crecen.</h1>
    <p class="hero-subtitle">
      Fondo Lunaria · Aquelarre Laboratorio de Diseño Feminista
    </p>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: var(--spacing-xl, 32px);
    background-color: var(--bg-sand);
    text-align: center;
  }

  .hero-content {
    max-width: 720px;
  }

  .hero-tag {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--wood-accent);
    display: block;
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-main);
    margin: 0 0 24px;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-main);
    margin: 0;
    opacity: 0.85;
  }
</style>
