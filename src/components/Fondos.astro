---
/**
 * Fondos.astro — Capas de fondo del Informe de Gestión 2025
 *
 * Props:
 *   desde  (default 0)  — primera sección a mostrar
 *   hasta  (default 16) — última sección a mostrar
 *
 * Cada capa ocupa 1/N de la altura total (--alto).
 * El posicionamiento se recalcula automáticamente según el rango.
 */

import { readFileSync } from "node:fs";
import { join } from "node:path";

export interface Props {
  desde?: number;
  hasta?: number;
}

const { desde = 0, hasta = 16 } = Astro.props;

const TOTAL_GLOBAL = 17;
const SECCIONES = [
  "Portada", "Carta", "Apoyamos",
  "Programas — Libertad y Democracia",
  "Programas — Autonomía y Sostenibilidad",
  "Fondo en Movimiento", "Investigación", "Diseño e ilustración",
  "Testimonios", "Cuentas Claras", "Territorios",
  "Detalle de programas", "Alianzas", "Investigación",
  "Proyección", "Agradecimientos", "Cierre",
] as const;

const BASE = join(process.cwd(), "public", "resources", "fondos");

const TOTAL = hasta - desde + 1;
const ALTURA = 100 / TOTAL;

const FONDOS = Array.from({ length: TOTAL_GLOBAL }, (_, i) => {
  const nro = String(i + 1).padStart(2, "0");
  let lqip = "";
  try {
    const buf = readFileSync(join(BASE, `fondo-seccion-${nro}-lqip.webp`));
    lqip = `data:image/webp;base64,${buf.toString("base64")}`;
  } catch { /* sin LQIP */ }

  return {
    nro,
    seccion: SECCIONES[i],
    src: `/resources/fondos/fondo-seccion-${nro}.webp`,
    srcSm: `/resources/fondos/fondo-seccion-${nro}-sm.webp`,
    lqip,
    alt: `${SECCIONES[i]}, ilustración de Aquelarre Laboratorio de Diseño Feminista`,
  };
});

const visibles = FONDOS.slice(desde, hasta + 1).map((f, i) => ({
  ...f,
  top: i * ALTURA,
  eager: i < 3,
  esPrimero: i === 0,
}));
---

<div class="fondos" aria-hidden="true" style={`--total: ${TOTAL}`}>
  {visibles.map((f) => (
    <div
      class={`fondos__capa fondos__capa--${f.nro}`}
      style={`top: ${f.top.toFixed(4)}%; height: ${ALTURA.toFixed(4)}%`}
    >
      {f.lqip && (
        <div class="fondos__lqip" style={`background-image: url(${f.lqip})`} />
      )}
      <picture>
        <source srcset={f.srcSm} media="(max-width: 640px)" />
        <img
          class="fondos__img"
          src={f.src}
          alt={f.alt}
          loading={f.eager ? "eager" : "lazy"}
          decoding="async"
          fetchpriority={f.esPrimero ? "high" : "auto"}
        />
      </picture>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll(".fondos__img").forEach((el) => {
    if (!(el instanceof HTMLImageElement)) return;
    const img = el;
    const revelar = () => {
      img.style.opacity = "1";
      const lqip = img.closest(".fondos__capa")?.querySelector(".fondos__lqip");
      if (lqip instanceof HTMLElement) lqip.style.opacity = "0";
    };
    if (img.complete && img.naturalWidth > 0) {
      revelar();
    } else {
      img.addEventListener("load", revelar, { once: true });
      img.addEventListener("error", () => { img.style.opacity = "1"; }, { once: true });
    }
  });
</script>

<style>
  .fondos {
    position: absolute;
    inset: 0;
    width: 100%;
    height: var(--alto);
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }

  .fondos__capa {
    position: absolute;
    left: 0;
    width: 100%;
    overflow: hidden;
    user-select: none;
  }

  .fondos__lqip {
    position: absolute;
    inset: -2%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(14px);
    z-index: 0;
    transition: opacity 0.3s ease;
  }

  .fondos__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 0.5s ease;
    will-change: opacity;
  }
</style>
